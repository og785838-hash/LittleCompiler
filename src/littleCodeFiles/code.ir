LABEL main
LINK
STOREF 1.0 $T1
STOREF $T1 x
STOREF 2.0 $T2
STOREF $T2 y
STOREF 3.14159 $T3
STOREF $T3 z
WRITEF x
WRITES newline
WRITEF z
WRITES newline
WRITEF y
WRITES newline
STOREF 2.0 $T4
DIVF z $T4 $T5
STOREF $T5 x
DIVF z y $T6
STOREF $T6 y
WRITEF x
WRITES newline
WRITEF y
WRITES newline
ADDF x y $T7
STOREF $T7 t
WRITEF t
WRITES newline
RET
